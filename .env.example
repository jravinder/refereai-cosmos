# RefereAI x Cosmos Reason 2 Configuration

# NVIDIA NGC API Key (required for NIM container deployment)
# Get yours at: https://build.nvidia.com/nvidia/cosmos-reason2-8b
COSMOS_API_KEY=nvapi-your-key-here

# Cosmos endpoint — defaults to local vLLM or NIM container
# For vLLM (recommended):
#   vllm serve nvidia/Cosmos-Reason2-8B --reasoning-parser qwen3 --port 8000
# For NIM container on Jetson AGX Orin:
#   docker run --gpus all -p 8000:8000 nvcr.io/nim/nvidia/cosmos-reason2-8b:latest
# For Nebius cloud deployment:
#   COSMOS_ENDPOINT=https://your-nebius-endpoint/v1
COSMOS_ENDPOINT=http://localhost:8000/v1

# Model
COSMOS_MODEL=nvidia/cosmos-reason2-8b
